# Supabase Configuration
# Get these values from your Supabase project dashboard
# https://supabase.com/dashboard/project/YOUR_PROJECT/settings/api

# ── LOCAL DEVELOPMENT ────────────────────────────────────────────────────────
# Point directly at your Supabase project (fine on a dev machine).
VITE_SUPABASE_URL=https://your-project-ref.supabase.co
VITE_SUPABASE_ANON_KEY=your-anon-key-here

# ── VERCEL PRODUCTION (ISP bypass) ───────────────────────────────────────────
# On Vercel, override VITE_SUPABASE_URL to route all Supabase calls through
# your own domain so Indian ISPs (blocking *.supabase.co) can't interfere.
#
#   VITE_SUPABASE_URL=https://chai-paani.vercel.app/api/supabase
#
# The /api/supabase/[...path] Vercel function proxies to the real Supabase URL
# stored in SUPABASE_URL (server-side only — never exposed to the browser).

# Server-side Supabase URL (used by the /api/supabase proxy function)
SUPABASE_URL=https://your-project-ref.supabase.co

# Required for Edge Functions (server-side operations like email invites)
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key-here

# ── GOOGLE OAUTH RELAY (ISP bypass) ──────────────────────────────────────────
# Set VITE_GOOGLE_PROXY_ENABLED=true in Vercel to use the custom relay instead
# of Supabase's built-in OAuth (which redirects through *.supabase.co).
#
# The relay lives at:
#   /api/auth/google          — starts OAuth (redirects to Google)
#   /api/auth/google/callback — exchanges code for id_token, then redirects app

VITE_GOOGLE_PROXY_ENABLED=false   # set to "true" in Vercel production

# Your deployed app URL (no trailing slash) — used by the relay functions
APP_URL=https://chai-paani.vercel.app

# Google OAuth credentials — create at https://console.cloud.google.com/
# Authorized redirect URI must include: https://chai-paani.vercel.app/api/auth/google/callback
GOOGLE_CLIENT_ID=your-google-client-id.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=your-google-client-secret
